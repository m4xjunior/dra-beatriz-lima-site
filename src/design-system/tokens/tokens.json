{
  "$schema": "https://tr.designtokens.org/format/",
  "$description": "Dra. Beatriz Lima — Biomédica Esteta. Fonte única de tokens (W3C Design Tokens). Projeção CSS em /tokens/*.css. Camadas: primitive (color/typography/scale/effect) → semantic (temas brand/immersive/ops) → component.",
  "color": {
    "$type": "color",
    "sand": {
      "50": { "$value": "#FBF9F4" }, "100": { "$value": "#F6F1E8" },
      "200": { "$value": "#EEE6D7" }, "300": { "$value": "#E3D8C5" }, "400": { "$value": "#CBBBA0" }
    },
    "ink": {
      "400": { "$value": "#8B8070" }, "500": { "$value": "#635A4C" }, "600": { "$value": "#4A4236" },
      "700": { "$value": "#342E25" }, "800": { "$value": "#241F18" },
      "900": { "$value": "#1A1611", "$description": "Preto quente — nunca #000." }
    },
    "obsidian": {
      "$description": "Base do tema immersive — quente, nunca #000.",
      "950": { "$value": "#0C0A07" }, "900": { "$value": "#100D09" }, "850": { "$value": "#15110B" },
      "800": { "$value": "#1C1710" }, "700": { "$value": "#262017" }, "600": { "$value": "#342C20" }
    },
    "gold": {
      "$description": "Bronze → champanhe. Acento e tipografia; tratamento metálico/reflexivo.",
      "100": { "$value": "#F4E8CC" }, "200": { "$value": "#E9D3A3" }, "300": { "$value": "#DBBE7C" },
      "400": { "$value": "#C9A65C" }, "500": { "$value": "#B58E45", "$description": "Dourado da marca." },
      "600": { "$value": "#997438" }, "700": { "$value": "#7A5B2B", "$description": "Texto pequeno AA sobre creme." },
      "800": { "$value": "#5C4420" }
    },
    "champagne": { "$value": "#F7EDD6", "$description": "Highlight metálico." },
    "nude": { "100": { "$value": "#F5E6DC" }, "200": { "$value": "#E9CDBC" }, "300": { "$value": "#D8AF9A" } },
    "status": {
      "success": { "$value": "#5E7A5A" }, "warning": { "$value": "#A9793A" },
      "danger": { "$value": "#9B4A3F" }, "info": { "$value": "#4A6670" }
    }
  },
  "font": {
    "family": {
      "$type": "fontFamily",
      "display": { "$value": ["Bricolage Grotesque", "Space Grotesk", "system-ui", "sans-serif"], "$description": "Grotesca contemporânea — substitui a Didone." },
      "body": { "$value": ["Mulish", "Segoe UI", "system-ui", "sans-serif"] },
      "serif": { "$value": ["Cormorant Garamond", "Garamond", "Georgia", "serif"], "$description": "Só em citações." }
    },
    "weight": {
      "$type": "fontWeight",
      "light": { "$value": 300 }, "regular": { "$value": 400 }, "medium": { "$value": 500 },
      "semibold": { "$value": 600 }, "bold": { "$value": 700 }, "black": { "$value": 800 }
    },
    "size": {
      "$type": "dimension",
      "2xs": { "$value": "0.6875rem" }, "xs": { "$value": "0.75rem" }, "sm": { "$value": "0.875rem" },
      "base": { "$value": "1rem" }, "md": { "$value": "1.125rem" }, "lg": { "$value": "1.3125rem" },
      "xl": { "$value": "1.625rem" }, "2xl": { "$value": "2rem" }, "3xl": { "$value": "2.625rem" },
      "4xl": { "$value": "3.375rem" }, "5xl": { "$value": "4.25rem" }, "6xl": { "$value": "5.5rem" }
    }
  },
  "lineHeight": {
    "$type": "number",
    "tight": { "$value": 1.05 }, "snug": { "$value": 1.22 }, "normal": { "$value": 1.5 }, "relaxed": { "$value": 1.7 }
  },
  "letterSpacing": {
    "$type": "dimension",
    "tighter": { "$value": "-0.03em" }, "tight": { "$value": "-0.015em" }, "normal": { "$value": "0em" },
    "wide": { "$value": "0.06em" }, "wider": { "$value": "0.14em" }, "widest": { "$value": "0.26em" }
  },
  "size": {
    "$type": "dimension",
    "0": { "$value": "0" }, "1": { "$value": "0.25rem" }, "2": { "$value": "0.5rem" }, "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" }, "5": { "$value": "1.5rem" }, "6": { "$value": "2rem" }, "7": { "$value": "3rem" },
    "8": { "$value": "4rem" }, "9": { "$value": "6rem" }, "10": { "$value": "8rem" }, "11": { "$value": "10rem" }, "12": { "$value": "12rem" }
  },
  "radius": {
    "$type": "dimension",
    "$description": "Suaves (12–22px) — amigáveis ao vidro.",
    "none": { "$value": "0" }, "xs": { "$value": "4px" }, "sm": { "$value": "8px" }, "md": { "$value": "12px" },
    "lg": { "$value": "16px" }, "xl": { "$value": "22px" }, "2xl": { "$value": "30px" }, "pill": { "$value": "999px" }
  },
  "shadow": {
    "$type": "shadow",
    "sm": { "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px", "spread": "0", "color": "rgba(26,22,17,0.06)" } },
    "md": { "$value": { "offsetX": "0", "offsetY": "6px", "blur": "20px", "spread": "-6px", "color": "rgba(26,22,17,0.12)" } },
    "lg": { "$value": { "offsetX": "0", "offsetY": "18px", "blur": "48px", "spread": "-12px", "color": "rgba(26,22,17,0.18)" } },
    "xl": { "$value": { "offsetX": "0", "offsetY": "30px", "blur": "80px", "spread": "-16px", "color": "rgba(26,22,17,0.28)" } }
  },
  "gradient": {
    "$type": "gradient",
    "gold": { "$description": "Assinatura — bronze → champanhe. 135deg.", "$value": [
      { "color": "{color.gold.800}", "position": 0 }, { "color": "{color.gold.600}", "position": 0.32 },
      { "color": "{color.gold.400}", "position": 0.66 }, { "color": "{color.gold.200}", "position": 1 } ] },
    "metal": { "$description": "Reflexivo/metálico — texto e bordas. 135deg com pico champanhe.", "$value": [
      { "color": "{color.gold.700}", "position": 0 }, { "color": "{color.gold.400}", "position": 0.22 },
      { "color": "{color.champagne}", "position": 0.42 }, { "color": "{color.gold.400}", "position": 0.60 },
      { "color": "{color.gold.600}", "position": 0.78 }, { "color": "{color.gold.200}", "position": 1 } ] },
    "goldText": { "$description": "Preto→dourado em texto display (background-clip).", "$value": [
      { "color": "{color.ink.900}", "position": 0 }, { "color": "{color.gold.700}", "position": 0.58 },
      { "color": "{color.gold.500}", "position": 1 } ] }
  },
  "effect": {
    "$description": "Nova pele: vidro, bloom, mesh, grão. Composições theme-neutras; aliases invertem por tema.",
    "glass": {
      "blur": { "$type": "dimension", "$value": "18px" },
      "saturate": { "$type": "number", "$value": 1.4 },
      "bgLight": { "$type": "color", "$value": "rgba(251,249,244,0.55)" },
      "bgDark": { "$type": "color", "$value": "rgba(28,23,16,0.42)" },
      "borderLight": { "$type": "color", "$value": "rgba(255,255,255,0.65)" },
      "borderDark": { "$type": "color", "$value": "rgba(219,190,124,0.20)" }
    },
    "bloom": {
      "$type": "shadow",
      "soft": { "$value": { "offsetX": "0", "offsetY": "0", "blur": "24px", "spread": "-6px", "color": "rgba(201,166,92,0.35)" } },
      "base": { "$value": { "offsetX": "0", "offsetY": "8px", "blur": "40px", "spread": "-8px", "color": "rgba(201,166,92,0.45)" } },
      "strong": { "$value": { "offsetX": "0", "offsetY": "10px", "blur": "60px", "spread": "-6px", "color": "rgba(201,166,92,0.60)" } }
    },
    "mesh": {
      "$description": "Fundos orgânicos radiais, muito discretos (brand claro / immersive escuro).",
      "brand": { "$value": "radial-gradient layers — creme + ouro sobre sand" },
      "immersive": { "$value": "radial-gradient layers — âmbar/ouro sobre obsidiana" }
    },
    "grain": {
      "$description": "Textura fina de filme (feTurbulence SVG) sobreposta.",
      "opacityLight": { "$type": "number", "$value": 0.045 },
      "opacityDark": { "$type": "number", "$value": 0.07 }
    },
    "tilt": {
      "$description": "Inclinação 3D dos cards.",
      "max": { "$type": "dimension", "$value": "8deg" },
      "perspective": { "$type": "dimension", "$value": "900px" }
    }
  },
  "theme": {
    "$description": "Temas semânticos derivados dos mesmos primitivos. Troca por [data-theme] no <html>.",
    "brand": { "$description": "Claro, sereno, dimensional — site público. PADRÃO." },
    "immersive": { "$description": "Obsidiana escura — 3D/simulação. Ouro com bloom; vidro vivo." },
    "ops": { "$description": "Interno/ERP (Tauri) — neutro, denso, sem vidro, sans em tudo." }
  },
  "semantic": {
    "$description": "O que os componentes consomem (tema brand mostrado). Contraste AA verificado.",
    "text": {
      "$type": "color",
      "body": { "$value": "{color.ink.900}", "$extensions": { "contrast": { "on": "sand.100", "ratio": 16.2, "aa": true } } },
      "muted": { "$value": "{color.ink.500}", "$extensions": { "contrast": { "on": "sand.100", "ratio": 5.9, "aa": true } } },
      "subtle": { "$value": "{color.ink.400}", "$extensions": { "contrast": { "on": "sand.100", "ratio": 3.4, "aa": "large-only" } } },
      "accent": { "$value": "{color.gold.700}", "$extensions": { "contrast": { "on": "sand.100", "ratio": 5.5, "aa": true } } },
      "onInverse": { "$value": "{color.sand.50}", "$extensions": { "contrast": { "on": "obsidian.900", "ratio": 16.8, "aa": true } } },
      "accentImmersive": { "$value": "{color.gold.300}", "$extensions": { "contrast": { "on": "obsidian.900", "ratio": 8.9, "aa": true } } }
    }
  }
}
