---
// /procedimentos/[slug] — página de um procedimento. O slug É o id da
// entrada (nome do arquivo .md) — não existe campo "slug" redundante.
import BaseLayout from "../../layouts/BaseLayout.astro";
import Badge from "../../components/Badge.astro";
import Divider from "../../components/Divider.astro";
import Disclaimer from "../../components/Disclaimer.astro";
import GradientTitle from "../../components/GradientTitle.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const procedimentos = await getCollection(
    "procedimentos",
    ({ data }) => data.publicado
  );
  return procedimentos.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { data } = item;
const { Content } = await render(item);
---

<BaseLayout
  title={data.seoTitulo ?? `${data.titulo} — Dra. Beatriz Lima`}
  description={data.seoDescricao ?? data.resumo}
  theme="brand"
>
  <article class="pagina-procedimento">
    <header class="pagina-procedimento__cabecalho" data-bl-reveal>
      {data.carroChefe && <Badge tone="ouro">Carro-chefe</Badge>}
      <p class="pagina-procedimento__eyebrow">{data.eyebrow}</p>
      <GradientTitle as="h1" size="3xl">{data.titulo}</GradientTitle>
      <p class="pagina-procedimento__resumo">{data.resumo}</p>
      {
        data.duracaoMedia && (
          <p class="pagina-procedimento__meta">
            Duração média do atendimento: {data.duracaoMedia}
          </p>
        )
      }
    </header>

    <Divider fade />

    <div class="pagina-procedimento__corpo" data-bl-reveal>
      <Content />
    </div>

    <div class="pagina-procedimento__grade" data-bl-reveal>
      <section class="pagina-procedimento__ficha">
        <h2 class="pagina-procedimento__subtitulo">
          <span class="pagina-procedimento__chave" aria-hidden="true">{"{"}</span>
          Indicações
        </h2>
        <ul class="pagina-procedimento__lista">
          {data.indicacoes.map((linha) => <li>{linha}</li>)}
        </ul>
      </section>

      <section class="pagina-procedimento__ficha">
        <h2 class="pagina-procedimento__subtitulo">
          <span class="pagina-procedimento__chave" aria-hidden="true">{"{"}</span>
          Contraindicações
        </h2>
        <ul class="pagina-procedimento__lista">
          {data.contraindicacoes.map((linha) => <li>{linha}</li>)}
        </ul>
      </section>

      {
        data.cuidadosPosProcedimento && (
          <section class="pagina-procedimento__ficha">
            <h2 class="pagina-procedimento__subtitulo">
              <span class="pagina-procedimento__chave" aria-hidden="true">{"{"}</span>
              Cuidados após o procedimento
            </h2>
            <ul class="pagina-procedimento__lista">
              {data.cuidadosPosProcedimento.map((linha) => <li>{linha}</li>)}
            </ul>
          </section>
        )
      }
    </div>

    {
      data.notaPreco && (
        <p class="pagina-procedimento__preco" data-bl-reveal>{data.notaPreco}</p>
      )
    }

    <Divider fade />

    <Disclaimer variant="geral" extra={data.disclaimerExtra} />
  </article>
</BaseLayout>

<style>
  .pagina-procedimento {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding: var(--space-section) var(--space-container-pad) var(--space-stack-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-lg);
  }

  .pagina-procedimento__cabecalho {
    display: flex;
    flex-direction: column;
    gap: var(--space-stack-xs);
  }

  .pagina-procedimento__eyebrow {
    font-family: var(--type-eyebrow-font);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--type-eyebrow-tracking);
    color: var(--text-accent);
    margin: var(--space-stack-xs) 0 0;
  }

  .pagina-procedimento__resumo {
    font-size: var(--font-size-md);
    line-height: var(--type-body-leading);
    color: var(--text-muted);
    margin: 0;
  }

  .pagina-procedimento__meta {
    font-size: var(--font-size-xs);
    color: var(--text-subtle);
    margin: 0;
  }

  .pagina-procedimento__corpo {
    font-size: var(--font-size-md);
    line-height: var(--type-body-leading);
    color: var(--text-body);
  }

  .pagina-procedimento__corpo :global(p) {
    margin: 0 0 var(--space-stack-sm);
  }

  .pagina-procedimento__grade {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-stack-lg);
  }

  .pagina-procedimento__ficha {
    /* Ficha de vidro estático — sem backdrop-filter: o fundo da página
       é --surface-base plano, sem mesh/textura atrás; blur sem nada
       pra desfocar é custo de composição sem ganho visual. */
    background-color: var(--card-glass-bg);
    border: var(--border-width-hairline) solid var(--card-glass-border);
    border-radius: var(--card-glass-radius);
    box-shadow: var(--card-glass-shadow);
    padding: var(--space-stack-md);
  }

  .pagina-procedimento__subtitulo {
    display: flex;
    align-items: baseline;
    gap: var(--space-inline-sm);
    font-family: var(--type-display-font);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-lg);
    color: var(--text-heading);
    margin: 0 0 var(--space-stack-xs);
  }

  .pagina-procedimento__chave {
    font-size: var(--font-size-xl);
    line-height: 1;
    background: var(--gradient-gold-text);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .pagina-procedimento__lista {
    margin: 0;
    padding-left: var(--space-inline-md);
    color: var(--text-muted);
    font-size: var(--font-size-sm);
    line-height: var(--type-body-leading);
  }

  .pagina-procedimento__lista li {
    margin-bottom: var(--space-inline-xs);
  }

  .pagina-procedimento__preco {
    font-size: var(--font-size-sm);
    color: var(--text-subtle);
    font-style: italic;
  }

  @media (min-width: 768px) {
    .pagina-procedimento__grade {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
