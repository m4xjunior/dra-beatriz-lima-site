---
// /procedimentos — catálogo completo. Cadastrar um novo procedimento é
// adicionar um .md em src/content/procedimentos/ — esta página não muda.
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import Divider from "../../components/Divider.astro";
import GradientTitle from "../../components/GradientTitle.astro";
import { getCollection } from "astro:content";

const procedimentos = (
  await getCollection("procedimentos", ({ data }) => data.publicado)
).sort((a, b) => a.data.ordem - b.data.ordem);
---

<BaseLayout
  title="Procedimentos — Dra. Beatriz Lima"
  description="Conheça os procedimentos oferecidos pela Dra. Beatriz Lima: preenchimento labial, bioestimuladores, toxina botulínica, peelings e protocolos de pele."
  theme="brand"
>
  <section class="pagina-procedimentos">
    <div class="pagina-procedimentos__cabecalho-wrap">
      <div class="pagina-procedimentos__fundo" data-bl-parallax="0.12" aria-hidden="true"></div>
      <div class="pagina-procedimentos__cabecalho" data-bl-reveal>
        <p class="pagina-procedimentos__eyebrow">CATÁLOGO</p>
        <GradientTitle as="h1" size="4xl">Procedimentos</GradientTitle>
        <p class="pagina-procedimentos__corpo">
          Cada procedimento começa por uma avaliação individual. As
          indicações e contraindicações abaixo são gerais — a decisão sobre
          o que é adequado para você é sempre clínica, conversada em
          consulta.
        </p>
      </div>
    </div>

    <Divider fade />

    <div class="pagina-procedimentos__grade">
      {
        procedimentos.map((item) => (
          <ServiceCard
            slug={item.id}
            eyebrow={item.data.eyebrow}
            title={item.data.titulo}
            summary={item.data.resumo}
            featured={item.data.carroChefe}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .pagina-procedimentos {
    max-width: var(--container-xl);
    margin-inline: auto;
    padding: var(--space-section) var(--space-container-pad);
  }

  .pagina-procedimentos__cabecalho-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-card);
  }

  /* overflow:hidden fica só neste wrapper do cabeçalho — NUNCA na
     <section> inteira, que contém o grid de ServiceCard logo abaixo:
     o tilt deles (data-bl-tilt) usa scale()+box-shadow que seriam
     cortados por um ancestral com overflow:hidden. */
  .pagina-procedimentos__fundo {
    position: absolute;
    inset: -15% -5%;
    background-color: var(--surface-sunken);
    background-image: var(--surface-mesh);
    opacity: 0.55;
    z-index: -1;
  }

  .pagina-procedimentos__cabecalho {
    max-width: var(--container-prose);
    padding: var(--space-stack-md) var(--space-inline-md);
    margin-bottom: var(--space-stack-lg);
  }

  .pagina-procedimentos__eyebrow {
    font-family: var(--type-eyebrow-font);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: var(--type-eyebrow-tracking);
    color: var(--text-accent);
    margin: 0 0 var(--space-stack-xs);
  }

  .pagina-procedimentos__corpo {
    font-size: var(--font-size-md);
    line-height: var(--type-body-leading);
    color: var(--text-muted);
    margin-top: var(--space-stack-sm);
  }

  .pagina-procedimentos__grade {
    display: grid;
    /* Fluida por natureza: 1 coluna no mobile (o mínimo já não cabe em
       dobro na largura da viewport) até 3+ no desktop, sem breakpoint
       fixo arbitrário — só a matemática do clamp() decidindo. */
    grid-template-columns: repeat(auto-fit, minmax(clamp(16rem, 38vw, 21rem), 1fr));
    gap: var(--space-gutter);
    margin-top: var(--space-stack-lg);
  }
</style>
