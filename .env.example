# Variáveis de ambiente do projeto — copie para .env e ajuste (nunca
# commite o .env real; já está no .gitignore).

# --- Build do site (Astro / Vite) ------------------------------------
# Base da API do servidor Rust (server/), usada por
# src/components/face-viewer-3d-captura.ts e src/pages/simulacao-3d/ver.astro
# e src/pages/simulacoes/testar.astro. Vazia = mesma origem (só funciona
# quando o site é servido PELO PRÓPRIO servidor Rust, não no Cloudflare
# Pages puro). Se o site estiver publicado separado do backend, aponte para
# a URL pública onde o servidor Rust estiver rodando.
PUBLIC_API_BASE_URL=

# --- Servidor Rust (server/) ------------------------------------------
# Porta de escuta. Default 8080 se ausente/inválida.
PORT=8080

# Nível de log via `tracing`. Default "info".
RUST_LOG=info

# String de conexão Postgres (módulo de simulações, server/src/simulacoes.rs).
# Opcional: se ausente/inacessível, o servidor sobe normalmente e só
# /api/simulacoes responde 503 (capturas e estático continuam funcionando).
DATABASE_URL=postgres://localhost/estetica_beatriz

# --- Docker Compose (docker-compose.yml) -------------------------------
# Só usadas pelo `docker compose up` (deploy self-hosted em qualquer VPS
# com Docker) — sem relação com rodar o binário direto na máquina de dev.
# Senha do Postgres DENTRO do container (não é a do Postgres local do Mac).
POSTGRES_PASSWORD=troque-esta-senha-antes-de-subir-em-producao
# Porta publicada no host para o serviço `app`. Default 8080.
APP_PORT=8080
